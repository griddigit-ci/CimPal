<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1278.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eu.griddigit.cimpal.main.application.controllers.ValidationByMappingController">

    <VBox spacing="10.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </padding>

        <Label text="Validation by Mapping">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Validation workflow:" wrapText="true"/>
                <Label fx:id="helpValidationWorkflow"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <ChoiceBox fx:id="cbValidationWorkflow" minWidth="350.0" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Mapping CSV file:" wrapText="true"/>
                <Label fx:id="helpMappingCsvFile"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <TextField fx:id="tfMappingCsvFile"
                       editable="false"
                       promptText="Select a .csv mapping file"
                       HBox.hgrow="ALWAYS"/>

            <Button minWidth="80.0"
                    mnemonicParsing="false"
                    onAction="#actionBrowseMappingCsv"
                    text="Browse"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Models / input root folder:" wrapText="true"/>
                <Label fx:id="helpModelsInputFolder"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <TextField fx:id="tfModelsInputFolder"
                       editable="false"
                       promptText="Select model root folder or timestamped input root folder"
                       HBox.hgrow="ALWAYS"/>

            <Button minWidth="80.0"
                    mnemonicParsing="false"
                    onAction="#actionBrowseModelsInputFolder"
                    text="Browse"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Constraints root folder:" wrapText="true"/>
                <Label fx:id="helpConstraintsRootFolder"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <TextField fx:id="tfConstraintsRootFolder"
                       editable="false"
                       promptText="Select constraints root folder"
                       HBox.hgrow="ALWAYS"/>

            <Button minWidth="80.0"
                    mnemonicParsing="false"
                    onAction="#actionBrowseConstraintsRootFolder"
                    text="Browse"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Output folder:" wrapText="true"/>
                <Label fx:id="helpOutputFolder"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <TextField fx:id="tfOutputFolder"
                       editable="false"
                       promptText="Select output folder"
                       HBox.hgrow="ALWAYS"/>

            <Button minWidth="80.0"
                    mnemonicParsing="false"
                    onAction="#actionBrowseOutputFolder"
                    text="Browse"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Datatype map:" wrapText="true"/>
                <Label fx:id="helpDatatypeMap"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <ChoiceBox fx:id="cbDatatypeMap" minWidth="350.0" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <HBox minWidth="170.0" spacing="5.0" alignment="CENTER_LEFT">
                <Label text="XML base URI:" wrapText="true"/>
                <Label fx:id="helpXmlBaseUri"
                       text="?"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 20;
                              -fx-border-color: #808080;
                              -fx-border-radius: 20;
                              -fx-text-fill: #333333;
                              -fx-font-weight: bold;
                              -fx-alignment: center;
                              -fx-min-width: 18px;
                              -fx-min-height: 18px;
                              -fx-pref-width: 18px;
                              -fx-pref-height: 18px;
                              -fx-cursor: hand;"/>
            </HBox>

            <TextField fx:id="tfXmlBaseUri"
                       text="http://iec.ch/TC57/CIM100"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <ProgressBar fx:id="pbValidationByMapping" prefWidth="Infinity" progress="0.0"/>

        <HBox alignment="BOTTOM_RIGHT" spacing="10.0">
            <Button minWidth="90.0"
                    mnemonicParsing="false"
                    onAction="#actionResetValidationByMapping"
                    text="Reset"/>

            <Button fx:id="btnRunValidationByMapping"
                    minWidth="90.0"
                    mnemonicParsing="false"
                    onAction="#actionRunValidationByMapping"
                    text="Run"/>
        </HBox>

    </VBox>
</AnchorPane>