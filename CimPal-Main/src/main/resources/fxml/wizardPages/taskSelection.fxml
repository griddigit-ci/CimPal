<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eu.griddigit.cimpal.main.application.controllers.taskWizardControllers.TaskSelectionController">
   <top>
       <TitledPane animated="false" collapsible="false" text="RDFS" BorderPane.alignment="CENTER">
           <AnchorPane>
               <Label layoutX="27.0" layoutY="14.0" text="Select RDFS Profile Version:" />
               <ChoiceBox fx:id="fcbProfileVersionIDG" layoutX="199.0" layoutY="10.0" prefHeight="26.0" prefWidth="322.0" />
               <Label layoutX="28.0" layoutY="56.0" text="Base Namespace: " />
               <TextArea fx:id="rdfsProfileBaseNamespaceTextField" disable="true" layoutX="199.0" layoutY="44.0" prefHeight="18.0" prefWidth="322.0" wrapText="true" />
               <Label layoutX="838.0" layoutY="56.0" text="RDFS Format:" />
               <ChoiceBox fx:id="rdfsFormatsDropdown" disable="true" layoutX="931.0" layoutY="52.0" prefWidth="150.0" />
               <Button fx:id="rdfsProfileBrowseButton" disable="true" layoutX="835.0" layoutY="10.0" mnemonicParsing="false" onAction="#actionBrowseProfileIDG" prefHeight="26.0" prefWidth="247.0" text="Browse" />
               <TextArea fx:id="fieldTextProfileIDG" editable="false" layoutX="582.0" layoutY="9.0" prefHeight="71.0" prefWidth="239.0" wrapText="true" HBox.hgrow="ALWAYS" />
           </AnchorPane>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
       </TitledPane>
   </top>
   <center>
       <TitledPane animated="false" collapsible="false" prefHeight="50.0" text="Instance Model" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <content>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                     <Label text="Base Instance Model:" />
                     <TextArea fx:id="baseInstanceModelFilesPaths" editable="false" wrapText="true" HBox.hgrow="ALWAYS" />
                     <Button mnemonicParsing="false" onAction="#browseBaseInstance" text="Browse" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>
         </content>
       </TitledPane>
   </center>
   <bottom>
      <HBox alignment="BASELINE_CENTER" prefHeight="250.0" BorderPane.alignment="CENTER">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                   <TableView fx:id="tableForSelectedTasks" editable="true">
                     <columns>
                         <TableColumn minWidth="50.0" prefWidth="-1.0" style="-fx-alignment: CENTER;" text="Order">
                             <cellValueFactory>
                                 <PropertyValueFactory property="order" />
                             </cellValueFactory>
                         </TableColumn>
                         <TableColumn minWidth="300.0" prefWidth="-1.0" text="Task">
                             <cellValueFactory>
                                 <PropertyValueFactory property="name" />
                             </cellValueFactory>
                         </TableColumn>
                         <TableColumn fx:id="removeColumn" minWidth="100.0" prefWidth="-1.0" style="-fx-alignment: CENTER; -fx-underline: true;" text="Action">
                             <cellValueFactory>
                                 <PropertyValueFactory property="action" />
                             </cellValueFactory>
                         </TableColumn>
                     </columns>
                   </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox nodeOrientation="LEFT_TO_RIGHT" HBox.hgrow="ALWAYS">
               <children>
                   <Label text="Select tasks in order of execution:" />
                   <ListView fx:id="tasksForSelection" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</BorderPane>
