            <Label layoutX="167.0" layoutY="12.0" text="Multiply CGM config XLS:" />
            <TextField fx:id="loadedXMLFile" editable="false" layoutX="308.0" layoutY="7.0" prefHeight="26.0" prefWidth="434.0" HBox.hgrow="ALWAYS" />
            <Button disable="false" layoutX="753.0" layoutY="7.0" mnemonicParsing="false" onAction="#actionBrowseMultiplyCGMFiles" prefHeight="26.0" prefWidth="152.0" text="Browse" />
