<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="133.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.taskControllers.MultiplyNTimesAndConnectController">
    <TitledPane animated="false" collapsible="false" layoutX="11.0" layoutY="8.0" prefHeight="115.0" prefWidth="1180.0"
                text="Multiply Base Model N Times And Connect">
        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="73.0" prefWidth="714.0">
            <Label layoutX="29.0" layoutY="12.0" text="Multiply N times:"/>
            <TextField fx:id="timesToMultiply" layoutX="684.0" layoutY="7.0" prefHeight="26.0" prefWidth="269.0"/>
            <Label layoutX="29.0" layoutY="50.0" text="Connect to Connectivity Node Id (with _):"/>
            <TextField fx:id="connectivityNodeId" layoutX="683.0" layoutY="45.0" prefHeight="26.0"
                       prefWidth="271.0"/>

            <CheckBox fx:id="saveResult" layoutX="989.0" layoutY="12.0" mnemonicParsing="false" selected="true"
                      text="Save Result to Working Dir"/>
        </AnchorPane>
    </TitledPane>
</AnchorPane>
