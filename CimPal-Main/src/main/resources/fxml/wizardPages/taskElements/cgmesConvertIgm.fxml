<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="190.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eu.griddigit.cimpal.main.application.controllers.taskWizardControllers.CgmesConvertIgmController">

    <TitledPane animated="false" collapsible="false"
                layoutX="11.0" layoutY="8.0"
                prefHeight="170.0" prefWidth="1180.0"
                text="CGMES 2.4 → 3.0: Convert IGM (multi-file selection)">

        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="150.0" prefWidth="1180.0">

            <Label layoutX="29.0" layoutY="18.0" text="IGM files (EQ/SSH/TP/SV):"/>
            <TextField fx:id="tfIgmFiles" editable="false"
                       layoutX="200.0" layoutY="12.0" prefHeight="26.0" prefWidth="567.0"/>
            <Button layoutX="785.0" layoutY="12.0" mnemonicParsing="false"
                    prefHeight="26.0" prefWidth="120.0"
                    text="Browse" onAction="#actionBrowseIgmFiles"/>

            <CheckBox fx:id="cbKeepExtensions" layoutX="200.0" layoutY="58.0"
                      mnemonicParsing="false" text="Keep extensions in the IGM" selected="true"/>

            <CheckBox fx:id="cbConvertOnlyEq" layoutX="420.0" layoutY="58.0"
                      mnemonicParsing="false" text="Convert only EQ"/>

            <CheckBox fx:id="cbAlignRegControlTargets" layoutX="580.0" layoutY="58.0"
                      mnemonicParsing="false" text="Model improvement: Align regulating control targets"/>

            <CheckBox fx:id="saveResult" layoutX="989.0" layoutY="18.0"
                      mnemonicParsing="false" selected="true" text="Save Result to Working Dir"/>

        </AnchorPane>
    </TitledPane>
</AnchorPane>