<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="taskInputAnchorPane" prefHeight="400.0" prefWidth="1230.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eu.griddigit.cimpal.main.application.controllers.taskWizardControllers.TaskInputController">
   <VBox spacing="10">
      <ScrollPane prefHeight="472.0" prefWidth="1220.0">
         <VBox fx:id="vBoxForTaskInputs" prefHeight="457.0" prefWidth="1190.0" spacing="10" />
      </ScrollPane>
      <HBox spacing="10">
         <Label />
         <Button fx:id="buttonSelectWorkingDirectory" mnemonicParsing="false" onAction="#selectWorkingDirectory" text="Select Working Directory" />
         <Button mnemonicParsing="false" onAction="#selectOutputDirectory" text="Select Output Directory" />
         <CheckBox fx:id="saveToZip" mnemonicParsing="false" selected="true" prefHeight="22.0" prefWidth="131.0" text="Compress files to zip" />
      </HBox>
   </VBox>
</AnchorPane>
