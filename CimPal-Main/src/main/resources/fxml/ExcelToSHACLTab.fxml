<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="eu.griddigit.cimpal.main.application.controllers.ExcelToSHACLController"
            prefHeight="180.0" prefWidth="200.0">
    <VBox prefHeight="431.0" prefWidth="1278.0" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="RDF file:" wrapText="true" />
            <TextField fx:id="fPathRdffileForExcel" editable="false" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#actionBrowseRDFfileForExcel" text="Browse" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="RDFS format:" wrapText="true" />
            <ChoiceBox fx:id="fcbRDFSformatForExcel" minWidth="400.0" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Input - Excel file:" wrapText="true" />
            <TextField fx:id="fPathXLSfileForShape" editable="false" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#actionBrowseExcelfileForShape" text="Browse" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Base URI - Shape graph:" wrapText="true" />
            <TextField fx:id="fbaseURIShapeExcel" HBox.hgrow="ALWAYS" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Namespace information for the resulted Shape graph:" wrapText="true" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Prefix:" wrapText="true" />
            <TextField fx:id="fPrefixExcelShape" prefWidth="70.0" />
            <Label minWidth="90.0" text="Namespace:" wrapText="true" />
            <TextField fx:id="fNSexcelShape" HBox.hgrow="ALWAYS" />
        </HBox>
        <!-- New: Excel→TTL change inputs -->
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="40.0" />
            </padding>
            <Label minWidth="90.0" text="Modify Constraints from xls file" wrapText="true" />
        </HBox>
        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Changes Excel:" wrapText="true" />
            <TextField fx:id="fPathXLSChangesExcelToTtl" editable="false" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#actionBrowseXlsChangesExcelToTtl" text="Browse" />
        </HBox>

        <HBox spacing="10.0">
            <padding>
                <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
            <Label minWidth="90.0" text="Target TTL:" wrapText="true" />
            <TextField fx:id="fPathTTLChangesExcelToTtl" editable="false" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#actionBrowseTtlChangesExcelToTtl" text="Browse" />
        </HBox>
        <!-- New: Left-side Run/Reset for Excel→TTL -->
        <HBox alignment="BOTTOM_LEFT" spacing="10.0" VBox.vgrow="NEVER">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" />
            </VBox.margin>
            <Button fx:id="btnRunExcelToTtl" minWidth="60.0" mnemonicParsing="false" onAction="#actionBtnRunExcelToTtl" text="Run" />
            <Button fx:id="btnResetExcelToTtl" minWidth="60.0" mnemonicParsing="false" onAction="#actionBtnResetExcelToTtl" text="Reset" />
        </HBox>
        <HBox alignment="BOTTOM_LEFT" nodeOrientation="RIGHT_TO_LEFT" spacing="10.0" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets bottom="5.0" right="5.0" />
            </VBox.margin>
            <Button fx:id="btnRunExcelShape" minWidth="60.0" mnemonicParsing="false" onAction="#actionBtnRunExcelShape" text="Run" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnResetExcelShape" minWidth="60.0" mnemonicParsing="false" onAction="#actionBtnResetExcelShape" text="Reset" />
        </HBox>
    </VBox>
</AnchorPane>
