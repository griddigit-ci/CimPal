<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="eu.griddigit.cimpal.main.application.controllers.RDFComparisonController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox spacing="12.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          style="-fx-padding: 10;">
        <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="140.0" prefWidth="170.0" hgrow="NEVER" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="95.0" prefWidth="95.0" hgrow="NEVER" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="NEVER" />
                        <RowConstraints vgrow="NEVER" />
                        <RowConstraints vgrow="NEVER" />
                    </rowConstraints>

                    <Label text="RDF file A (Model A):"
                           wrapText="true"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0" />
                    <TextField fx:id="fPathRdffile1"
                               editable="false"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"
                               GridPane.hgrow="ALWAYS" />
                    <Button text="Browse"
                            mnemonicParsing="false"
                            onAction="#actionBrowseRDFfile1"
                            minWidth="95.0"
                            GridPane.rowIndex="0"
                            GridPane.columnIndex="2" />

                    <Label text="RDF file B (Model B):"
                           wrapText="true"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0" />
                    <TextField fx:id="fPathRdffile2"
                               editable="false"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"
                               GridPane.hgrow="ALWAYS" />
                    <Button text="Browse"
                            mnemonicParsing="false"
                            onAction="#actionBrowseRDFfile2"
                            minWidth="95.0"
                            GridPane.rowIndex="1"
                            GridPane.columnIndex="2" />

                    <Label text="RDF scope and format:"
                           wrapText="true"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0" />
                    <HBox spacing="10.0"
                          GridPane.rowIndex="2"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="2"
                          HBox.hgrow="ALWAYS">
                        <ChoiceBox fx:id="fcbRDFSformat"
                                   prefWidth="220.0"
                                   HBox.hgrow="ALWAYS" />
                        <CheckBox fx:id="fcbRDFcompareCimVersion"
                                  mnemonicParsing="false"
                                  text="Assume same CIM namespace"
                                  wrapText="true" />
                    </HBox>
                </GridPane>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <CheckBox fx:id="fcbRDFcompareProfileNS"
                              mnemonicParsing="false"
                              text="Assume same Profile/Ontology namespace for prefix:"
                              wrapText="true" />
                    <TextField fx:id="fPrefixRDFCompare"
                               HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="btnResetRDFComp"
                            mnemonicParsing="false"
                            onAction="#actionBtnResetRDFComp"
                            text="Reset"
                            minWidth="90.0" />
                    <Button fx:id="btnRunRDFcompare"
                            disable="true"
                            mnemonicParsing="false"
                            onAction="#actionBtnRunRDFcompare"
                            text="Run"
                            minWidth="90.0" />
                </HBox>
    </VBox>
</AnchorPane>
