<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox minHeight="400.0" minWidth="600.0" prefHeight="600.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eu.griddigit.cimpal.main.application.controllers.sparql.SparqlResultsWindowController">
    <HBox spacing="10.0">
        <VBox.margin>
            <Insets left="5.0" right="5.0" top="5.0" />
        </VBox.margin>
        <Label text="Query Results:" />
        <Label fx:id="lblResultCount" />
    </HBox>
    <VBox VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" />
        </VBox.margin>
        <TableView fx:id="tableResults" VBox.vgrow="ALWAYS" />
    </VBox>
    <ButtonBar>
        <buttons>
            <Button fx:id="btnExport" mnemonicParsing="false" onAction="#actionExport" text="Export to Excel" />
            <Button fx:id="btnClose" cancelButton="true" mnemonicParsing="false" onAction="#actionClose" text="Close" />
        </buttons>
        <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
        </VBox.margin>
    </ButtonBar>
</VBox>

