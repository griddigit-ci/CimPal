                                            </panes>
                                          </Accordion>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </AnchorPane>
                     </content>
                  </Tab>
                  <Tab text="Task Wizard">
                    <content>
                      <AnchorPane maxHeight="-Infinity" prefHeight="595.0">
