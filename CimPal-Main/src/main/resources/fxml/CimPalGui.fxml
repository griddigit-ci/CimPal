                                                                     <padding>
                                                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                                                     </padding>
                                                                  </VBox>
                                                                  <VBox alignment="BOTTOM_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                                                     <children>
                                                                        <CheckBox fx:id="hideEmptySheets" disable="true" mnemonicParsing="false" nodeOrientation="RIGHT_TO_LEFT" text="Hide empty sheets" />
                                                                        <Label fx:id="label_geninfo" alignment="CENTER_RIGHT" maxWidth="290.0" nodeOrientation="LEFT_TO_RIGHT" text="Load RDFS and/or Instance data to generate template." textFill="RED" wrapText="true" />
                                                                        <Button alignment="BOTTOM_RIGHT" mnemonicParsing="false" onAction="#actionCreateXlsTemplate" text="Generate template" />
                                                                     </children>
                                                                     <padding>
                                                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                                                     </padding>
                                                                  </VBox>
                                                               </children>
                                                            </HBox>
                                                         </children>
                                                      </AnchorPane>
                                                </content>
                                              </TitledPane>
                                              <TitledPane prefHeight="162.0" prefWidth="1282.0" text="Create CIMXML dataset based on xlsx template">
                                                <content>
                                                  <AnchorPane>
                                                         <children>
                                                            <VBox spacing="5.0">
                                                               <children>
                                                                  <HBox spacing="10.0">
                                                                     <padding>
                                                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                                                     </padding>
                                                                     <children>
                                                                        <Label text="XLS template:" wrapText="true" />
