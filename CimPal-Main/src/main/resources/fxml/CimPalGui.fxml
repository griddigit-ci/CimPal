                                                                        <Button mnemonicParsing="false" onAction="#actionBrowseXlsTemplate" text="Browse" />
                                                                     </children>
                                                                     <VBox.margin>
                                                                        <Insets top="10.0" />
                                                                     </VBox.margin>
                                                                  </HBox>
                                                                  <HBox spacing="10.0">
                                                                     <padding>
                                                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                                                     </padding>
                                                                     <Label minWidth="50.0" prefHeight="17.0" prefWidth="89.0" text="Sorting options:" />
