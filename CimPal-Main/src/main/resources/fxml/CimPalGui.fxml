                                     <fx:include fx:id="wizardPane" source="wizardPages/taskSelection.fxml" />
                                  </center>
                                  <bottom>
                                     <VBox spacing="10">
                                        <HBox />
                                        <HBox prefHeight="0.0" prefWidth="1264.0" spacing="10">
                                           <Label />
                                           <Button mnemonicParsing="false" onAction="#backWizardPane" text="Back" />
                                           <Button fx:id="forwardWizardButton" mnemonicParsing="false" onAction="#forwardWizardPane" text="Next" />
                                        </HBox>
                                     </VBox>
                                  </bottom>
                               </BorderPane>
                            </VBox>
                           </children>
                      </AnchorPane>
                    </content>
                  </Tab>
                  <Tab fx:id="tabSPARQLQuery" text="SPARQL Query">
                    <content>
                      <fx:include fx:id="sparqlQueryTab" source="sparqlQueryTab.fxml" />
                    </content>
                  </Tab>
               </TabPane>
            </HBox>
