                                                                  <HBox spacing="10.0">
                                                                     <padding>
                                                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                                                     </padding>
                                                                     <children>
                                                                        <CheckBox fx:id="fcbStripPrefixesGen" minWidth="150.0" mnemonicParsing="false" selected="true" text="Strip declaration of unused prefixes" />
                                                                        <CheckBox fx:id="fcbExportExtensionsGen" minWidth="150.0" mnemonicParsing="false" selected="true" text="Export extensions (identified extensions in the template)" />
                                                                     </children>
                                                                  </HBox>
                                                                  <HBox nodeOrientation="RIGHT_TO_LEFT" spacing="10.0">
                                                                     <children>
                                                                        <Button fx:id="fbtnRunGenerateInstance" minWidth="60.0" mnemonicParsing="false" onAction="#actionBtnRunGenerateInstance" text="Create" HBox.hgrow="ALWAYS" />
