                                                                     </children>
                                                                     <padding>
                                                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                                                     </padding>
                                                                  </VBox>
                                                                  <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
                                                                     <children>
                                                                        <Label text="Loaded Instance files" />
                                                                        <ListView fx:id="ls_geni_instances" VBox.vgrow="ALWAYS" />
                                                                        <Button mnemonicParsing="false" onAction="#actionLoadInstanceDataGen" text="Load Instance data" />
